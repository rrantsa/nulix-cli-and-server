[Unit]
Description=Nulix FastAPI service
After=network-online.target ollama.service
Wants=network-online.target
Requires=ollama.service

[Service]
Type=simple
User=nulix
Group=nulix
WorkingDirectory=/opt/nulix/server
EnvironmentFile=-/etc/nulix-api.env
ExecStart=/opt/nulix/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --app-dir /opt/nulix/server
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
